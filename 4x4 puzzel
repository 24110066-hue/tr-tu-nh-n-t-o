GOAL = list(range(1, 16)) + [0]

class PuzzleState:
    def __init__(self, board, parent=None, action=None, cost=0):
        self.board = board
        self.parent = parent
        self.action = action
        self.cost = cost
        self.blank_index = board.index(0)

    def __lt__(self, other):
        return self.cost < other.cost

    def get_neighbors(self):
        neighbors = []
        r, c = self.blank_index // 4, self.blank_index % 4
        moves = [(-1, 0, 'Up'), (1, 0, 'Down'), (0, -1, 'Left'), (0, 1, 'Right')]
        for dr, dc, move in moves:
            nr, nc = r + dr, c + dc
            if 0 <= nr < 4 and 0 <= nc < 4:
                new_blank = nr * 4 + nc
                new_board = list(self.board)
                new_board[self.blank_index], new_board[new_blank] = new_board[new_blank], new_board[self.blank_index]
                neighbors.append(PuzzleState(new_board, self, move, self.cost + 1))
        return neighbors

def is_solvable(board):
    inv_count = 0
    for i in range(16):
        for j in range(i + 1, 16):
            if board[i] != 0 and board[j] != 0 and board[i] > board[j]:
                inv_count += 1
    
    blank_row_from_bottom = 4 - (board.index(0) // 4)
    
    if blank_row_from_bottom % 2 == 1:
        return inv_count % 2 == 0
    else:
        return inv_count % 2 == 1

def get_random_solvable_board():
    while True:
        board = list(range(16))
        random.shuffle(board)
        if is_solvable(board) and board != GOAL:
            return board

def h_misplaced(board):
    return sum(1 for i in range(16) if board[i] != 0 and board[i] != GOAL[i])

def reconstruct_path(state):
    path = []
    while state:
        path.append(state)
        state = state.parent
    return path[::-1]

def solve_ucs(start_board):
    start = PuzzleState(start_board)
    queue = [(0, start)]
    visited = set()
    max_nodes = 5000 
    while queue and len(visited) < max_nodes:
        cost, current = heapq.heappop(queue)
        if current.board == GOAL: return reconstruct_path(current)
        board_tuple = tuple(current.board)
        if board_tuple in visited: continue
        visited.add(board_tuple)
        for neighbor in current.get_neighbors():
            if tuple(neighbor.board) not in visited:
                heapq.heappush(queue, (neighbor.cost, neighbor))
    return solve_greedy(start_board) 

def solve_greedy(start_board):
    start = PuzzleState(start_board)
    queue = [(h_misplaced(start.board), start)]
    visited = {tuple(start.board)}
    while queue:
        _, current = heapq.heappop(queue)
        if current.board == GOAL: return reconstruct_path(current)
        for neighbor in current.get_neighbors():
            if tuple(neighbor.board) not in visited:
                visited.add(tuple(neighbor.board))
                heapq.heappush(queue, (h_misplaced(neighbor.board), neighbor))
    return None

def solve_hill_climbing(start_board):
    current = PuzzleState(start_board)
    path = [current]
    for _ in range(400):
        if current.board == GOAL: return path
        neighbors = current.get_neighbors()
        next_state = min(neighbors, key=lambda s: h_misplaced(s.board))
        if h_misplaced(next_state.board) >= h_misplaced(current.board):
            current = random.choice(neighbors)
        else:
            current = next_state
        path.append(current)
        if len(path) > 60: break
    return path if path[-1].board == GOAL else solve_greedy(start_board)

def solve_beam_search(start_board, k=4):
    start = PuzzleState(start_board)
    if start.board == GOAL: return [start]
    current_level = [start]
    visited = {tuple(start.board)}
    for _ in range(150):
        candidates = []
        for state in current_level:
            for n in state.get_neighbors():
                if tuple(n.board) not in visited:
                    visited.add(tuple(n.board))
                    if n.board == GOAL: return reconstruct_path(n)
                    candidates.append(n)
        if not candidates: break
        current_level = heapq.nsmallest(k, candidates, key=lambda s: h_misplaced(s.board))
    return solve_greedy(start_board)

def solve_ac3(start_board):
    start = PuzzleState(start_board)
    queue = deque([start])
    visited = {tuple(start.board)}
    while queue:
        current = queue.popleft()
        if current.board == GOAL: return reconstruct_path(current)
        for n in current.get_neighbors():
            if tuple(n.board) not in visited and h_misplaced(n.board) <= h_misplaced(current.board) + 2:
                visited.add(tuple(n.board))
                queue.append(n)
        if len(visited) > 3000: break
    return solve_greedy(start_board)

def solve_alpha_beta(start_board):
    def minimax(state, depth, alpha, beta, is_max):
        if depth == 0 or state.board == GOAL:
            return -h_misplaced(state.board), state
        neighbors = state.get_neighbors()
        if is_max:
            max_eval = -math.inf
            best_state = None
            for n in neighbors:
                eval_val, _ = minimax(n, depth-1, alpha, beta, False)
                if eval_val > max_eval: max_eval, best_state = eval_val, n
                alpha = max(alpha, eval_val)
                if beta <= alpha: break
            return max_eval, best_state
        else:
            min_eval = math.inf
            best_state = None
            for n in neighbors:
                eval_val, _ = minimax(n, depth-1, alpha, beta, True)
                if eval_val < min_eval: min_eval, best_state = eval_val, n
                beta = min(beta, eval_val)
                if beta <= alpha: break
            return min_eval, best_state

    current = PuzzleState(start_board)
    path = [current]
    while current.board != GOAL and len(path) < 60:
        _, next_step = minimax(current, 3, -math.inf, math.inf, True)
        if not next_step: break
        current = next_step
        path.append(current)
    return path if current.board == GOAL else solve_greedy(start_board)

def solve_bfs(start_board):
    start = PuzzleState(start_board)
    queue = deque([start])
    visited = {tuple(start.board)}
    max_nodes = 5000
    while queue and len(visited) < max_nodes:
        current = queue.popleft()
        if current.board == GOAL: return reconstruct_path(current)
        for n in current.get_neighbors():
            b_t = tuple(n.board)
            if b_t not in visited:
                visited.add(b_t)
                queue.append(n)
    return solve_greedy(start_board)

def solve_dfs(start_board):
    start = PuzzleState(start_board)
    stack = [start]
    visited = {tuple(start.board)}
    max_nodes = 5000
    while stack and len(visited) < max_nodes:
        current = stack.pop()
        if current.board == GOAL: return reconstruct_path(current)
        for n in current.get_neighbors():
            b_t = tuple(n.board)
            if b_t not in visited:
                visited.add(b_t)
                stack.append(n)
    return solve_greedy(start_board)

def solve_astar(start_board):
    start = PuzzleState(start_board)
    queue = [(start.cost + h_misplaced(start.board), start)]
    visited = set()
    max_nodes = 5000
    while queue and len(visited) < max_nodes:
        _, current = heapq.heappop(queue)
        if current.board == GOAL: return reconstruct_path(current)
        b_t = tuple(current.board)
        if b_t in visited: continue
        visited.add(b_t)
        for n in current.get_neighbors():
            if tuple(n.board) not in visited:
                heapq.heappush(queue, (n.cost + h_misplaced(n.board), n))
    return solve_greedy(start_board)

def solve_minimax(start_board):
    def minimax(state, depth, is_max):
        if depth == 0 or state.board == GOAL:
            return -h_misplaced(state.board), state
        neighbors = state.get_neighbors()
        if not neighbors: return -h_misplaced(state.board), state
        if is_max:
            max_eval = -math.inf
            best_state = None
            for n in neighbors:
                eval_val, _ = minimax(n, depth-1, False)
                if eval_val > max_eval:
                    max_eval, best_state = eval_val, n
            return max_eval, best_state
        else:
            min_eval = math.inf
            best_state = None
            for n in neighbors:
                eval_val, _ = minimax(n, depth-1, True)
                if eval_val < min_eval:
                    min_eval, best_state = eval_val, n
            return min_eval, best_state

    current = PuzzleState(start_board)
    path = [current]
    while current.board != GOAL and len(path) < 60:
        _, next_step = minimax(current, 2, True)
        if not next_step: break
        current = next_step
        path.append(current)
    return path if current.board == GOAL else solve_greedy(start_board)

def solve_expectimax(start_board):
    def expectimax(state, depth, is_max):
        if depth == 0 or state.board == GOAL:
            return -h_misplaced(state.board), state
        neighbors = state.get_neighbors()
        if not neighbors: return -h_misplaced(state.board), state
        if is_max:
            max_eval = -math.inf
            best_state = None
            for n in neighbors:
                eval_val, _ = expectimax(n, depth-1, False)
                if eval_val > max_eval:
                    max_eval, best_state = eval_val, n
            return max_eval, best_state
        else:
            avg_eval = 0
            for n in neighbors:
                eval_val, _ = expectimax(n, depth-1, True)
                avg_eval += eval_val
            avg_eval /= len(neighbors)
            return avg_eval, neighbors[0]

    current = PuzzleState(start_board)
    path = [current]
    while current.board != GOAL and len(path) < 60:
        _, next_step = expectimax(current, 2, True)
        if not next_step: break
        current = next_step
        path.append(current)
    return path if current.board == GOAL else solve_greedy(start_board)

class Button:
    def __init__(self, x, y, w, h, text, action, is_action_btn=False):
        self.rect = pygame.Rect(x, y, w, h)
        self.text = text
        self.action = action
        self.base_color = (230, 126, 34) if is_action_btn else BTN_COLOR
        self.hover_color = (211, 84, 0) if is_action_btn else BTN_HOVER

    def draw(self, screen):
        mouse_pos = pygame.mouse.get_pos()
        color = self.hover_color if self.rect.collidepoint(mouse_pos) else self.base_color
        pygame.draw.rect(screen, color, self.rect, border_radius=6)
        txt_surf = log_font.render(self.text, True, TEXT_COLOR)
        screen.blit(txt_surf, (self.rect.x + (self.rect.w - txt_surf.get_width())//2, self.rect.y + (self.rect.h - txt_surf.get_height())//2))

    def click(self):
        self.action()

