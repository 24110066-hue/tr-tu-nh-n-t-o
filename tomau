        from IPython.display import display, clear_output
    except ImportError:
        print("[Thông báo] ipywidgets chưa được cài đặt. Hệ thống chuyển hướng tự động chạy CLI.")
        execute_coloring_pipeline(color_count=3, strategy="mrv", trigger_notebook_view=False)
        return

    banner = widgets.HTML("""
        <div style="background: linear-gradient(135deg, #2563eb, #4f46e5); color: white; padding: 15px 20px; border-radius: 10px; margin-bottom: 15px;">
            <h3 style="margin: 0; font-size: 20px;">Đồ Thị Tô Màu Thủ Đức - Interactive Dashboard</h3>
            <p style="margin: 5px 0 0; font-size: 13px; opacity: 0.9;">Tùy biến cấu hình mô phỏng, thuật toán phân rã cấu trúc không gian trạng thái.</p>
        </div>
    """)

    w_colors = widgets.Dropdown(options=[("3 Màu Cơ Bản", 3), ("4 Màu Nâng Cao", 4), ("5 Màu Toàn Diện", 5)], value=3, description="Số lượng màu:")
    w_strategy = widgets.Dropdown(options=[(label, key) for key, label in STRATEGY_LABELS.items()], value="mrv", description="Toán tử giải:")
    w_slider = widgets.IntSlider(value=120, min=20, max=400, step=10, description="Max Node cây:")
    w_output_path = widgets.Text(value="output_graph_coloring_pro", description="Thư mục xuất:")
    w_edges_input = widgets.Textarea(value=convert_edges_to_str(DIAG_EDGES), description="Dữ liệu cạnh kề:", layout=widgets.Layout(width="100%", height="200px"))
    
    help_box = widgets.HTML("""
        <div style="background: #f0fdf4; border-left: 4px solid #22c55e; padding: 10px; border-radius: 4px; margin: 10px 0; font-size: 12px; color: #166534;">
            <b>Cú pháp nạp dữ liệu cạnh tùy biến:</b> Cứ mỗi dòng biểu diễn một liên kết gạch ngang. Ví dụ: <code>Tên Vùng A - Tên Vùng B</code>
        </div>
    """)

    btn_run = widgets.Button(description="Bắt Đầu Tính Toán", button_style="success", icon="play")
    btn_reset = widgets.Button(description="Thiết Lập Mặc Định", button_style="warning", icon="undo")
    ui_output = widgets.Output()

    def click_reset_handler(_b):
        w_colors.value, w_strategy.value, w_slider.value = 3, "mrv", 120
        w_output_path.value = "output_graph_coloring_pro"
        w_edges_input.value = convert_edges_to_str(DIAG_EDGES)
        with ui_output:
            clear_output()
            print("Đã hoàn tác cấu hình mặc định ban đầu.")

    def click_run_handler(_b):
        with ui_output:
            clear_output()
            try:
                execute_coloring_pipeline(
                    color_count=w_colors.value, strategy=w_strategy.value,
                    custom_edges_text=w_edges_input.value, max_visible_tree_nodes=w_slider.value,
                    output_directory=w_output_path.value, trigger_notebook_view=True
                )
            except Exception as error:
                print(f"[LỖI THỰC THI]: {error}")

    btn_run.on_click(click_run_handler)
    btn_reset.on_click(click_reset_handler)

    layout_box = widgets.VBox([
        banner, widgets.HBox([w_colors, w_strategy]), w_slider, w_output_path,
        help_box, w_edges_input, widgets.HBox([btn_run, btn_reset]), ui_output
    ])
    display(layout_box)

def is_running_in_jupyter() -> bool:
    try:
        from IPython import get_ipython
        return get_ipython() is not None
    except Exception:
        return False

def main():
    parser = argparse.ArgumentParser(description="Công Cụ Tô Màu Đồ Thị Coresync Graph Coloring Tool CLI.")
    parser.add_argument("--mode", choices=["auto", "widget", "cli"], default="auto", help="Chế độ vận hành (Mặc định: auto)")
    parser.add_argument("--colors", type=int, choices=[3, 4, 5], default=3, help="Cấu hình số lượng màu")
    parser.add_argument("--strategy", choices=["normal", "degree", "mrv", "greedy"], default="mrv", help="Lựa chọn giải thuật")
    parser.add_argument("--max-nodes", type=int, default=120, help="Giới hạn node vẽ trên cây")
    parser.add_argument("--out-dir", default="output_graph_coloring_pro", help="Thư mục ghi nhận kết quả")
    
    args, _ = parser.parse_known_args()

    if args.mode == "widget":
        deploy_interactive_widgets()
        return

    if args.mode == "cli":
        execute_coloring_pipeline(color_count=args.colors, strategy=args.strategy, max_visible_tree_nodes=args.max_nodes, output_directory=args.out_dir, trigger_notebook_view=False)
        return

    if is_running_in_jupyter():
        deploy_interactive_widgets()
    else:
        execute_coloring_pipeline(color_count=args.colors, strategy=args.strategy, max_visible_tree_nodes=args.max_nodes, output_directory=args.out_dir, trigger_notebook_view=False)

if __name__ == "__main__":
    main()
