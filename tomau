def convert_edges_to_str(edges: List[Tuple[str, str]]) -> str:
    return "\n".join(f"{u} - {v}" for u, v in edges)

def parse_graph_inputs(raw_text: str) -> Tuple[List[str], List[Tuple[str, str]]]:
    parsed_edges: List[Tuple[str, str]] = []
    unique_regions: List[str] = []

    for idx, raw_line in enumerate(raw_text.splitlines(), start=1):
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue

        for delimiter in [" - ", ",", "-"]:
            if delimiter in line:
                nodes = line.split(delimiter, 1)
                break
        else:
            raise ValueError(f"Dòng {idx} sai cú pháp định dạng: '{raw_line}'. Vui lòng dùng: Vùng A - Vùng B")

        u, v = nodes[0].strip(), nodes[1].strip()
        if not u or not v:
            raise ValueError(f"Dòng {idx} bị thiếu thông tin tên khu vực.")
        if u == v:
            raise ValueError(f"Dòng {idx} lỗi: Vùng '{u}' không thể tự kề chính nó.")

        if (u, v) not in parsed_edges and (v, u) not in parsed_edges:
            parsed_edges.append((u, v))

        if u not in unique_regions: unique_regions.append(u)
        if v not in unique_regions: unique_regions.append(v)

    if not parsed_edges:
        raise ValueError("Lỗi: Danh sách quan hệ kề (cạnh) đang trống.")

    return unique_regions, parsed_edges

class MapColoringSolver:
    def __init__(self, regions: List[str], edges: List[Tuple[str, str]], colors: List[str], strategy: str):
        self.regions = regions
        self.edges = edges
        self.colors = colors
        self.strategy = strategy
        
        self.adjacency_list: Dict[str, List[str]] = defaultdict(list)
        self._initialize_graph()

        self.current_assignment: Dict[str, str] = {}
        self.tree_nodes: List[StateNode] = []
        self.logs: List[str] = []

        self.counter_tries = 0
        self.counter_violations = 0
        self.counter_backtracks = 0

    def _initialize_graph(self):
        for u, v in self.edges:
            if v not in self.adjacency_list[u]: self.adjacency_list[u].append(v)
            if u not in self.adjacency_list[v]: self.adjacency_list[v].append(u)
        for r in self.regions:
            self.adjacency_list.setdefault(r, [])

    def get_degree(self, region: str) -> int:
        return len(self.adjacency_list.get(region, []))

    def append_state_node(self, parent_id: Optional[int], label: str, status: str, depth: int) -> int:
        new_id = len(self.tree_nodes)
        self.tree_nodes.append(StateNode(new_id, parent_id, label, status, depth))
        return new_id

    def verify_safety(self, region: str, color: str) -> Tuple[bool, str]:
        for neighbor in self.adjacency_list[region]:
            if self.current_assignment.get(neighbor) == color:
                return False, f"Xung đột màu với {neighbor}"
        return True, "Hợp lệ"

    def get_valid_colors(self, region: str) -> List[str]:
        return [c for c in self.colors if self.verify_safety(region, c)[0]]

    def pick_next_region(self) -> Optional[str]:
        unassigned = [r for r in self.regions if r not in self.current_assignment]
        if not unassigned:
            return None

        if self.strategy == "normal":
            return unassigned[0]
        if self.strategy in ("degree", "greedy"):
            return max(unassigned, key=lambda r: self.get_degree(r))
        
        return min(unassigned, key=lambda r: (len(self.get_valid_colors(r)), -self.get_degree(r)))

    def execute_solve(self) -> bool:
        self.current_assignment.clear()
        self.tree_nodes.clear()
        self.logs.clear()
        
        self.counter_tries = 0
        self.counter_violations = 0
        self.counter_backtracks = 0

        if self.strategy == "greedy":
            return self._solve_with_greedy()

        root_node_id = self.append_state_node(None, "Khởi tạo\nAssignment = {}", "root", 0)
        self.logs.extend([
            "Khởi chạy tiến trình thuật toán Backtracking.",
            f"Chiến lược áp dụng: {STRATEGY_LABELS.get(self.strategy, self.strategy)}",
            f"Thông số quy mô: {len(self.regions)} vùng | {len(self.edges)} quan hệ kề",
            f"Danh sách màu chọn lựa: {', '.join(self.colors)}",
            "=" * 70
        ])

        is_found = self._backtrack_recursive(parent_id=root_node_id, depth=0)
        self.logs.extend(["=" * 70, f"KẾT LUẬN: { 'Đã tìm thấy lời giải hợp lệ.' if is_found else 'Không tồn tại phương án khả thi.'}"])
        return is_found

    def _backtrack_recursive(self, parent_id: int, depth: int) -> bool:
        if len(self.current_assignment) == len(self.regions):
            self.append_state_node(parent_id, "THÀNH CÔNG\nTìm thấy nghiệm", "solution", depth + 1)
            return True

        target_region = self.pick_next_region()
        if target_region is None:
            return False

        self.logs.append(f"Chọn vùng xử lý tiếp theo: {target_region}")

        for color in self.colors:
            self.counter_tries += 1
            is_safe, msg = self.verify_safety(target_region, color)

            if is_safe:
                self.current_assignment[target_region] = color
                child_id = self.append_state_node(parent_id, f"{target_region} = {color}\nKhả thi", "ok", depth + 1)
                self.logs.append(f" -> Thử gán: {target_region} = {color} [Thành công]")

                if self._backtrack_recursive(child_id, depth + 1):
                    return True

                self.counter_backtracks += 1
                self.logs.append(f" <- [Quay lui] Thu hồi màu của {target_region} = {color}")
                self.tree_nodes[child_id].status = "backtrack"
                self.tree_nodes[child_id].label = f"{target_region} = {color}\nQuay lui"
                del self.current_assignment[target_region]
            else:
                self.counter_violations += 1
                self.append_state_node(parent_id, f"{target_region} = {color}\nXung đột\n({msg})", "violation", depth + 1)
                self.logs.append(f" -> Thử gán: {target_region} = {color} [Thất bại: {msg}]")

        return False

    def _solve_with_greedy(self) -> bool:
        start_id = self.append_state_node(None, "Greedy Strategy", "root", 0)
        curr_parent = start_id
        
        sorted_order = sorted(self.regions, key=lambda r: self.get_degree(r), reverse=True)
        self.logs.extend([
            "Khởi chạy giải thuật Tham lam (Greedy Coloring).",
            f"Thứ tự duyệt ưu tiên bậc: {' -> '.join(sorted_order)}",
            "=" * 70
        ])

        for depth, region in enumerate(sorted_order, start=1):
            is_colored = False
            for color in self.colors:
                self.counter_tries += 1
                is_safe, reason = self.verify_safety(region, color)

                if is_safe:
                    self.current_assignment[region] = color
                    curr_parent = self.append_state_node(curr_parent, f"{region} = {color}\nOK", "ok", depth)
                    self.logs.append(f"Áp đặt: {region} = {color} -> Thành công")
                    is_colored = True
                    break
                
                self.counter_violations += 1
                self.append_state_node(curr_parent, f"{region} = {color}\nVi phạm\n{reason}", "violation", depth)
                self.logs.append(f"Thử gán lỗi tại {region} = {color} ({reason})")

            if not is_colored:
                self.logs.append(f"Lỗi hệ thống: Giải thuật Greedy thất bại bế tắc tại vùng [{region}]")
                return False

        self.append_state_node(curr_parent, "HOÀN THÀNH\nGreedy tìm được nghiệm", "solution", len(sorted_order) + 1)
        self.logs.extend(["=" * 70, "KẾT LUẬN: Thuật toán Tham lam tìm ra phương án thành công."])
        return True

    def self_validate(self) -> Tuple[bool, List[str]]:
        issues = []
        for r in self.regions:
            if r not in self.current_assignment:
                issues.append(f"Vùng '{r}' chưa được phân bổ màu.")
        for u, v in self.edges:
            if self.current_assignment.get(u) == self.current_assignment.get(v):
                issues.append(f"Cạnh kề sai luật: '{u}' và '{v}' cùng nhận màu '{self.current_assignment.get(u)}'")
        return len(issues) == 0, issues

def generate_layout_positions(regions: List[str]) -> Dict[str, Tuple[float, float]]:
    layout_pos = dict(MAP_POSITIONS)
    missing = [r for r in regions if r not in layout_pos]
    if not missing:
        return layout_pos

    cx, cy, radius = 3.0, 2.0, 2.5
    for idx, r in enumerate(missing):
        angle = 2 * math.pi * idx / max(len(missing), 1)
        layout_pos[r] = (cx + radius * math.cos(angle), cy + radius * math.sin(angle))
    return layout_pos

def fetch_hex_color(name: str, total_colors: int) -> str:
    for c_name, hex_code in PALETTES_CONFIG[total_colors]:
        if c_name == name: return hex_code
    return "#ffffff"

def render_colored_graph(solver: MapColoringSolver, total_colors: int, save_path: Path):
    positions = generate_layout_positions(solver.regions)
    fig, ax = plt.subplots(figsize=(12, 7.5))

    for u, v in solver.edges:
        x1, y1 = positions[u]
        x2, y2 = positions[v]
        ax.plot([x1, x2], [y1, y2], color="#4b5563", linewidth=1.5, zorder=1)

    for region in solver.regions:
        x, y = positions[region]
        c_name = solver.current_assignment.get(region, "Trống")
        hex_color = fetch_hex_color(c_name, total_colors)

        ax.scatter(x, y, s=2400, color=hex_color, edgecolors="#111827", linewidths=1.8, zorder=3)
        label_text = f"{region}\n({c_name})\nBậc: {solver.get_degree(region)}"
        ax.text(x, y, label_text, ha="center", va="center", fontsize=8, fontweight="bold", zorder=4)

    ax.set_title("BẢN ĐỒ TÔ MÀU ĐỒ THỊ KHU VỰC THỦ ĐỨC", fontsize=14, fontweight="bold", pad=15)
    ax.axis("off")
    ax.margins(0.15)
    fig.tight_layout()
    fig.savefig(save_path, dpi=200, bbox_inches="tight")
    plt.close(fig)

def format_node_text(text: str, line_width: int = 16) -> str:
    lines = []
    for section in text.splitlines():
        lines.extend(textwrap.wrap(section, width=line_width) or [section])
    return "\n".join(lines[:4] + ["..."] if len(lines) > 4 else lines)

def render_backtrack_tree(tree_nodes: List[StateNode], save_path: Path, max_nodes_display: int):
    if not tree_nodes:
        fig, ax = plt.subplots(figsize=(8, 4))
        ax.text(0.5, 0.5, "Không có dữ liệu cây quyết định hiển thị", ha="center", va="center")
        ax.axis("off")
        fig.savefig(save_path, dpi=200)
        plt.close(fig)
        return

    subset_nodes = tree_nodes[:max_nodes_display]
    subset_ids = {n.node_id for n in subset_nodes}
    
    tree_map: Dict[int, List[int]] = defaultdict(list)
    for n in subset_nodes:
        if n.parent_id is not None and n.parent_id in subset_ids:
            tree_map[n.parent_id].append(n.node_id)

    root_id = subset_nodes[0].node_id
    positions: Dict[int, Tuple[float, float]] = {}
    current_x = [0.0]

    def compute_layout(node_id: int, current_depth: int) -> float:
        sub_children = tree_map.get(node_id, [])
        if not sub_children:
            x_pos = current_x[0]
            current_x[0] += 1.0
        else:
            child_xs = [compute_layout(c, current_depth + 1) for c in sub_children]
            x_pos = sum(child_xs) / len(child_xs)
        positions[node_id] = (x_pos, -current_depth)
        return x_pos

    compute_layout(root_id, 0)
    fig_w = max(12, min(32, current_x[0] * 0.6))
    fig_h = max(7, min(24, max(n.depth for n in subset_nodes) * 1.2 + 2))
    
    fig, ax = plt.subplots(figsize=(fig_w, fig_h))

    for n in subset_nodes:
        if n.parent_id in positions and n.node_id in positions:
            x1, y1 = positions[n.parent_id]
            x2, y2 = positions[n.node_id]
            ax.plot([x1, x2], [y1, y2], color="#9ca3af", linewidth=1.0, zorder=1)

    styles = {
        "root": ("#e5e7eb", "#374151"), "ok": ("#bbf7d0", "#16a34a"),
        "violation": ("#fee2e2", "#dc2626"), "backtrack": ("#f3f4f6", "#9ca3af"),
        "solution": ("#bfdbfe", "#2563eb")
    }

    for n in subset_nodes:
        x, y = positions[n.node_id]
        bg_c, edge_c = styles.get(n.status, ("#ffffff", "#000000"))
        ax.scatter(x, y, s=1700, color=bg_c, edgecolors=edge_c, linewidths=1.2, zorder=3)
        ax.text(x, y, format_node_text(n.label), ha="center", va="center", fontsize=6.5, zorder=4)

    title_str = f"Cây Tìm Kiếm Không Gian Trạng Thái (Backtracking Tree) - Hiển thị {len(subset_nodes)}/{len(tree_nodes)} Nodes"
    ax.set_title(title_str, fontsize=14, fontweight="bold")
    ax.axis("off")
    fig.tight_layout()
    fig.savefig(save_path, dpi=200, bbox_inches="tight")
    plt.close(fig)

def export_to_csv_format(solver: MapColoringSolver, path: Path):
    with path.open("w", encoding="utf-8-sig", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(["Khu vực hành chính", "Màu gán", "Bậc liên kết", "Vùng giáp ranh kề"])
        for r in solver.regions:
            writer.writerow([r, solver.current_assignment.get(r, ""), solver.get_degree(r), ", ".join(solver.adjacency_list[r])])

