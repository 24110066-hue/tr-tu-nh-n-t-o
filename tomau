                    <tr><th>Khu vực</th><th>Màu được chỉ định</th><th>Bậc (Degree)</th><th>Khu vực giáp ranh</th></tr>
                </thead>
                <tbody>{table_rows}</tbody>
            </table>
        </div>
        <div class="card">
            <h3>Nhật Ký Thực Thi Thuật Toán</h3>
            <div class="console-log">{log_content}</div>
        </div>
    </div>
</body>
</html>
"""
    out_path.write_text(html_template, encoding="utf-8")

def execute_coloring_pipeline(
    color_count: int = 3,
    strategy: str = "mrv",
    custom_edges_text: Optional[str] = None,
    max_visible_tree_nodes: int = 120,
    output_directory: str = "output_graph_coloring_pro",
    trigger_notebook_view: bool = True
) -> ExecutionResult:
    
    if color_count not in PALETTES_CONFIG:
        raise ValueError("Yêu cầu tham số color_count phải nằm trong tập hợp [3, 4, 5]")
    if strategy not in STRATEGY_LABELS:
        raise ValueError(f"Chiến lược '{strategy}' không hợp lệ. Chọn lọc từ: {list(STRATEGY_LABELS.keys())}")

    if custom_edges_text is None:
        regions, edges = list(DIAG_REGIONS), list(DIAG_EDGES)
    else:
        regions, edges = parse_graph_inputs(custom_edges_text)

    available_colors = [name for name, _ in PALETTES_CONFIG[color_count]]
    
    solver = MapColoringSolver(regions, edges, available_colors, strategy)
    found_solution = solver.execute_solve()

    target_dir = Path(output_directory)
    target_dir.mkdir(parents=True, exist_ok=True)

    img_graph_p = target_dir / "visual_colored_map.png"
    img_tree_p = target_dir / "visual_execution_tree.png"
    csv_p = target_dir / "data_coloring_report.csv"
    html_p = target_dir / "dashboard_report.html"

    render_colored_graph(solver, color_count, img_graph_p)
    render_backtrack_tree(solver.tree_nodes, img_tree_p, max_visible_tree_nodes)
    export_to_csv_format(solver, csv_p)
    compose_html_report(solver, found_solution, color_count, strategy, img_graph_p, img_tree_p, html_p)

    metrics_block = {
        "regions_count": len(solver.regions), "edges_count": len(solver.edges),
        "colors_used": color_count, "total_attempts": solver.counter_tries,
        "violations_found": solver.counter_violations, "backtracks_performed": solver.counter_backtracks,
        "total_tree_nodes": len(solver.tree_nodes)
    }

    print_cli_dashboard(solver, found_solution, color_count, strategy, img_graph_p, img_tree_p, csv_p, html_p)

    if trigger_notebook_view:
        try:
            from IPython.display import HTML, display
            display(HTML(html_p.read_text(encoding="utf-8")))
        except Exception:
            pass

    return ExecutionResult(
        is_success=found_solution, coloring_map=dict(solver.current_assignment),
        execution_tree=list(solver.tree_nodes), execution_logs=list(solver.logs),
        output_path=target_dir, graph_img_path=img_graph_p, tree_img_path=img_tree_p,
        csv_path=csv_p, html_path=html_p, metrics=metrics_block
    )

def print_cli_dashboard(solver, solved, color_num, strat, img_g, img_t, csv_f, html_f):
    border = "=" * 70
    print(border)
    print("      HỆ THỐNG PHÂN TÍCH ĐỒ THỊ TÔ MÀU PHẲNG - THỦ ĐỨC CORESYNC     ")
    print(border)
    print(f"Trạng thái phương án : {'[THÀNH CÔNG] ĐÃ TÌM THẤY NGHIỆM' if solved else '[THẤT BẠI] VÔ NGHIỆM'}")
    print(f"Thuật toán áp dụng  : {STRATEGY_LABELS[strat]}")
